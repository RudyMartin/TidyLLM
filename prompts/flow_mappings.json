{
  "[Process MVR]": {
    "flow_encoding": "@mvr#process!extract@compliance_data",
    "template_names": ["mvr_analysis", "qa_control"],
    "processing_strategy": "multi_perspective",
    "priority_level": "high",
    "validation_rules": ["mvr_document_type", "compliance_standards"],
    "description": "Process Model Validation Report through complete compliance workflow"
  },
  "[Financial Analysis]": {
    "flow_encoding": "@financial#analysis!assess@risk_metrics",
    "template_names": ["financial_analysis", "qa_control"],
    "processing_strategy": "single_template",
    "priority_level": "normal",
    "validation_rules": ["financial_document_type"],
    "description": "Comprehensive financial document analysis and risk assessment"
  },
  "[Contract Review]": {
    "flow_encoding": "@contract#review!validate@legal_terms",
    "template_names": ["contract_analysis", "compliance_review"],
    "processing_strategy": "multi_perspective",
    "priority_level": "high",
    "validation_rules": ["legal_document_type", "contract_complexity"],
    "description": "Legal contract review with compliance validation"
  },
  "[Quality Check]": {
    "flow_encoding": "@quality#check!validate@standards",
    "template_names": ["qa_control"],
    "processing_strategy": "single_template",
    "priority_level": "normal",
    "validation_rules": ["quality_standards"],
    "description": "Quality assurance review and validation workflow"
  },
  "[Peer Review]": {
    "flow_encoding": "@peer#review!validate@expert_opinion",
    "template_names": ["peer_review", "qa_control"],
    "processing_strategy": "multi_perspective",
    "priority_level": "critical",
    "validation_rules": ["expert_review_required"],
    "description": "Expert peer review and professional validation"
  },
  "[Compliance Check]": {
    "flow_encoding": "@compliance#check!validate@regulations",
    "template_names": ["compliance_review", "qa_control"],
    "processing_strategy": "multi_perspective",
    "priority_level": "high",
    "validation_rules": ["regulatory_requirements"],
    "description": "Regulatory compliance analysis and risk assessment"
  },
  "[Data Extraction]": {
    "flow_encoding": "@data#extraction!extract@structured_data",
    "template_names": ["data_extraction"],
    "processing_strategy": "single_template",
    "priority_level": "normal",
    "validation_rules": ["data_structure_validation"],
    "description": "Structured data extraction and processing workflow"
  },
  "[Hybrid Analysis]": {
    "flow_encoding": "@hybrid#analysis!synthesize@multi_framework",
    "template_names": ["hybrid_analysis", "qa_control"],
    "processing_strategy": "hybrid_analysis",
    "priority_level": "high",
    "validation_rules": ["multi_framework_applicable"],
    "description": "Multi-dimensional document analysis combining multiple analytical perspectives"
  },
  "[Check MVS Compliance]": {
    "flow_encoding": "@compliance#check!validate@mvs_requirements",
    "template_names": ["compliance_review", "qa_control"],
    "processing_strategy": "single_template",
    "priority_level": "high",
    "validation_rules": ["MVS_5.4.3", "severity_threshold_medium"],
    "description": "Validate document against MVS 5.4.3 requirements"
  },
  "[Performance Test]": {
    "flow_encoding": "@performance#test!benchmark@operations",
    "template_names": ["qa_control", "data_extraction"],
    "processing_strategy": "single_template",
    "priority_level": "normal",
    "validation_rules": ["performance_metrics"],
    "description": "Run comprehensive performance benchmark operations"
  },
  "[Cost Analysis]": {
    "flow_encoding": "@cost#analysis!track@operations",
    "template_names": ["financial_analysis"],
    "processing_strategy": "single_template",
    "priority_level": "normal",
    "validation_rules": ["cost_tracking"],
    "description": "Analyze cost patterns and optimization opportunities"
  },
  "[Error Analysis]": {
    "flow_encoding": "@error#analysis!identify@failures",
    "template_names": ["qa_control"],
    "processing_strategy": "single_template",
    "priority_level": "high",
    "validation_rules": ["error_patterns"],
    "description": "Analyze error patterns and failure modes"
  },
  "[Integration Test]": {
    "flow_encoding": "@integration#test!validate@components",
    "template_names": ["qa_control"],
    "processing_strategy": "single_template",
    "priority_level": "normal",
    "validation_rules": ["integration_validation"],
    "description": "Test integration between components and external systems"
  },
  "[Document Section View]": {
    "flow_encoding": "@document#section!analyze@structure",
    "template_names": ["document_section_view"],
    "processing_strategy": "single_template",
    "priority_level": "normal",
    "validation_rules": ["document_structure"],
    "description": "Structured document section analysis for interactive browsing"
  }
}