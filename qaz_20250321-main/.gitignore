# =============================================================================
# PROJECT SPECIFIC
# =============================================================================
# VectorQA Sage specific files
logs/
*.log
data/processed/
data/raw/
data/temp/
compiled_modules/
backup/
backups/
*.backup
*.bak
*.tmp

# Tests folder (contains sensitive test data)
tests/

# Environment settings (SENSITIVE - deployment configs)
# NOTE: For deployment, we separate environ_settings from the main application:
# - Main app gets packaged/tested independently 
# - environ_settings contains deployment-specific configs and secrets
# - Deploy by extracting both packages at same directory level
# - This separation ensures secrets never mix with application code
environ_settings/

# Optional resources folders (reference materials, not part of main codebase)  
# Consolidated under optional/ directory - contains legacy code and reference materials
optional/
archive/
input/


# Temporary and draft files
changes for deno.md

# Restructured directories - ignore temporary files
frontend/static/temp/
backend/temp/
database/temp/
deploy/temp/
tests/temp/

# Test artifacts
test_results/
test_output/
coverage_html/
.pytest_cache/

# Documentation builds
docs/build/
docs/_build/

# Temporary files
temp/
tmp/
.tmp/

