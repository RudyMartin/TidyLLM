# VectorQA Sage - Comprehensive .gitignore

# =============================================================================
# CREDENTIALS & SECURITY
# =============================================================================
# NEVER commit these files - they contain sensitive information!
backend/config/credentials.env
backend/config/*.key
backend/config/*.pem
backend/config/*.p12
backend/config/secrets.json
backend/config/aws_credentials.json

# Environment files (but allow template)
*.env
.env.local
.env.production
.env.staging
.env.development

# Allow template files (safe to commit)
!backend/config/credentials_template.env
.env.production
.env.staging
.env.development
secrets/
secrets.json
credentials.json
api_keys.txt
tokens.txt

